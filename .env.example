# AI Agent Environment Configuration
# =====================================
# This is an example environment file (.env.example).
# Copy this file to .env and fill in your actual credentials.
# 
# IMPORTANT: Never commit the .env file with real credentials to version control!
# Always keep sensitive API keys secure and use .env.example for reference only.

# Azure OpenAI Configuration
# ============================
# Your Azure OpenAI endpoint URL
# Get this from Azure Portal > Your OpenAI Resource > Keys and Endpoint
API_ENDPOINT=https://your-resource-name.openai.azure.com/

# Your Azure OpenAI API key
# Get this from Azure Portal > Your OpenAI Resource > Keys and Endpoint
# Keep this secret! Never share or commit this key.
API_KEY=your-azure-openai-api-key-here

# Azure OpenAI API version
# Check Azure documentation for the latest supported version
# Format: YYYY-MM-DD-preview or YYYY-MM-DD
API_VERSION=2024-08-01-preview

# Azure OpenAI deployment model name
# This is the name you gave when creating the deployment in Azure
# Example: gpt-4-turbo, gpt-4, gpt-35-turbo, etc.
CHAT_MODEL_NAME=your-deployment-name

# OpenWeatherMap API Configuration
# ====================================
# Your OpenWeatherMap API key for weather data
# Get this from https://openweathermap.org/api
# Keep this secret! Never share or commit this key.
OPEN_WEATHER_API_KEY=your-openweathermap-api-key-here